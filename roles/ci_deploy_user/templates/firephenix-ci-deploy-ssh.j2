#!/usr/bin/env bash
set -euo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

SERVICES=()

if [ -n "${SSH_ORIGINAL_COMMAND:-}" ]; then
  while IFS= read -r line; do
    case "$line" in
      "docker compose up -d --no-deps "*)
        service_string=${line#"docker compose up -d --no-deps "}
        read -r -a SERVICES <<< "$service_string"
        ;;
    esac
  done <<< "$SSH_ORIGINAL_COMMAND"
fi

exec sudo -n {{ firephenix_ci_deploy_command_path | quote }} "${SERVICES[@]}"
