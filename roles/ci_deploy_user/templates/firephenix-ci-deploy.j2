#!/usr/bin/env bash
set -euo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
STACK_DIR={{ firephenix_ci_deploy_stack_dir | quote }}
LOG_FILE={{ firephenix_ci_deploy_log_file | quote }}
SERVICES=(
{%- for service in firephenix_ci_deploy_services %}
  {{ service | quote }}
{%- endfor %}
)

mkdir -p "$(dirname "$LOG_FILE")"
touch "$LOG_FILE"
chmod 0640 "$LOG_FILE"

exec > >(tee -a "$LOG_FILE") 2>&1

echo "[$(date --iso-8601=seconds)] Starting FirePhenix CI deploy"
cd "$STACK_DIR"

docker compose config --quiet
docker compose pull "${SERVICES[@]}"
docker compose up -d --no-deps "${SERVICES[@]}"
docker compose ps "${SERVICES[@]}"

echo "[$(date --iso-8601=seconds)] FirePhenix CI deploy finished"
